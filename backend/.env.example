# ──────────────────────────────────────────────
# Dona-Pol — Backend Environment Variables
# ──────────────────────────────────────────────

# Export this from MetaMask → Account Details → Export Private Key
# NEVER commit the real .env file to git
PRIVATE_KEY=your_wallet_private_key_here

# Get a free key at: https://alchemy.com
# Or use the public Amoy RPC (no key needed):
#   https://rpc-amoy.polygon.technology/
ALCHEMY_AMOY_RPC_URL=https://rpc-amoy.polygon.technology/

# Get test POL from the faucet: https://faucet.polygon.technology/
# (select "Polygon Amoy", paste your wallet address, request tokens)
